# House of Alex — environment variables
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored; NEVER commit real keys. Only NEXT_PUBLIC_* vars reach the browser.

# ─────────────────────────── Supabase ───────────────────────────
# Project URL — Dashboard → Project Settings → Data API. PUBLIC (safe).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"

# Anon / "publishable" key — PUBLIC. Safe to expose; guarded by RLS.
# (New projects: the `sb_publishable_...` key. Legacy: the `anon` JWT.)
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY"

# Service-role / "secret" key — SERVER ONLY. Bypasses RLS. NEVER prefix with
# NEXT_PUBLIC_ and never expose to the browser. (New: `sb_secret_...`.)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# ──────────────────────────── Resend ────────────────────────────
# API key — SERVER ONLY. Scope it to "Sending access" only.
RESEND_API_KEY="re_YOUR_RESEND_API_KEY"

# Verified sender on your verified domain (SPF/DKIM/DMARC configured in Resend).
RESEND_FROM_EMAIL="House of Alex <orders@your-domain.com>"

# Internal inbox that receives new wholesale orders + contact enquiries.
ORDER_INBOX_EMAIL="trade@your-domain.com"

# ─────────────────────────── Admin auth ─────────────────────────
# Comma-separated allowlist of admin emails. Only these can receive an OTP and
# reach the dashboard. SERVER ONLY (never NEXT_PUBLIC_).
ADMIN_EMAILS="you@your-domain.com"

# ──────────────────────────── App ───────────────────────────────
# Canonical site URL (used for links in emails / redirects). PUBLIC.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
